# ── TruthShield AI — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values

# Set to "false" to use real HuggingFace + OpenAI models
USE_MOCK=true

# OpenAI API Key (required when USE_MOCK=false)
OPENAI_API_KEY=sk-your-key-here

# MongoDB Atlas (optional, for logging detections)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/truthshield
